SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── OpenRouter AI ───────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model — any model slug from https://openrouter.ai/models
# Budget options:   mistralai/mistral-7b-instruct  |  google/gemma-2-9b-it:free
# Balanced options: google/gemini-flash-1.5        |  meta-llama/llama-3.1-70b-instruct
# Best quality:     anthropic/claude-3.5-sonnet    |  openai/gpt-4o
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=AI Learning Dashboard

# ─── Database (PostgreSQL for production) ─────────────────────────────────────
DB_NAME=ai_learning
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Redis / Celery (optional) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
